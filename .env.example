# Crea el archivo apps/api/.env con estas variables
# Obtén ambas URLs desde Supabase → Settings → Database → Connection string

# URL con pgBouncer (pooling) — para queries normales
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"

# URL directa — para migraciones de Prisma
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

PORT=3001
