generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Priority {
  ALTA
  MEDIA
  BAJA
}

enum ProjectType {
  MATERIA
  CURSO_ONLINE
  SIDE_PROJECT
}

enum TaskStatus {
  EN_PROGRESO
  PENDIENTE
  COMPLETADA
}

model Project {
  id          String       @id @default(cuid())
  name        String
  description String?
  type        ProjectType
  priority    Priority
  createdAt   DateTime     @default(now())
  tasks       Task[]
  sessions    StudySession[]
}

model Task {
  id          String     @id @default(cuid())
  projectId   String
  title       String
  description String?
  status      TaskStatus @default(PENDIENTE)
  priority    Priority
  dueDate     DateTime?
  createdAt   DateTime   @default(now())
  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model StudySession {
  id              String    @id @default(cuid())
  projectId       String
  startedAt       DateTime  @default(now())
  endedAt         DateTime?
  durationMinutes Int?
  project         Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
}
